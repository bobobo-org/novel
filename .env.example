# Copy to .env and fill in real values. .env is gitignored.
# These values should also be configured as GitHub repository secrets for CI.
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
SUPABASE_ACCESS_TOKEN=

# Google Gemini — server-side only (used by app/api/generate). Also set in Vercel env.
GOOGLE_GENERATIVE_AI_API_KEY=

# Cloud-only novel AI backend. Never put these values in frontend code.
AI_API_KEY=
AI_PROVIDER=google
AI_MODEL=gpt-4o-mini
AI_BASE_URL=https://api.openai.com/v1/chat/completions
DATABASE_URL=
ALLOWED_ORIGINS=https://novel-orcin.vercel.app,http://localhost:3000
APP_ENV=development
ADMIN_TOKEN=
