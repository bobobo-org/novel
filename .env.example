# Copy to .env and fill in real values. .env is gitignored.
# These values should also be configured as GitHub repository secrets for CI.
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
SUPABASE_ACCESS_TOKEN=

# Google Gemini — server-side only (used by app/api/generate). Also set in Vercel env.
GOOGLE_GENERATIVE_AI_API_KEY=
