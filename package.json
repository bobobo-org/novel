{
  "name": "zhutian-novel-system",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "eval:novel-ai": "node scripts/run-novel-ai-evals.mjs",
    "test:story-bible:l0a": "node scripts/run-story-bible-l0a-tests.mjs",
    "test:story-bible:l0a2e2": "node scripts/run-story-bible-l0a2e2-smoke.mjs",
    "test:story-bible:l0a2e2:contracts": "node scripts/run-story-bible-l0a2e2-contracts.mjs",
    "test:story-bible:l0a2e2:source-dedup": "node scripts/run-story-bible-l0a2e2-source-dedup.mjs",
    "test:story-bible:l0a2e2:concurrency": "node scripts/run-story-bible-l0a2e2-concurrency.mjs",
    "test:story-bible:l0a2e2:silent-fallback": "node scripts/run-story-bible-l0a2e2-silent-fallback.mjs",
    "test:story-bible:l0a2e2:all": "pnpm test:story-bible:l0a2e2:contracts && pnpm test:story-bible:l0a2e2 && pnpm test:story-bible:l0a2e2:source-dedup && pnpm test:story-bible:l0a2e2:concurrency && pnpm test:story-bible:l0a2e2:silent-fallback",
    "test:story-bible:l0a2:regression": "node --experimental-specifier-resolution=node scripts/run-story-bible-l0a2-regression.mjs",
    "test:story-bible:l0a2:parity": "node scripts/run-story-bible-l0a2-parity.mjs",
    "test:story-bible:l0a2:performance": "node --experimental-specifier-resolution=node scripts/run-story-bible-l0a2-performance.mjs",
    "test:story-bible:l0a2:full": "node scripts/run-story-bible-l0a2-full.mjs",
    "test:story-bible:l0a2:production-smoke": "node scripts/run-story-bible-c2c3-full-matrix.mjs",
    "test:story-bible:l0b1:sqlite-foundation": "node scripts/run-story-bible-l0b1-sqlite-foundation.mjs",
    "test:story-bible:l0b2:sqlite-core": "node --experimental-strip-types --import ./scripts/register-ts-extension-loader.mjs scripts/run-story-bible-l0b2-sqlite-core.mjs",
    "test:story-bible:l0b2:all": "pnpm build && pnpm check:storage-boundaries && pnpm test:story-bible:l0b1:sqlite-foundation && pnpm test:story-bible:l0b2:sqlite-core",
    "test:story-bible:l0b3:sqlite-export": "node --experimental-strip-types --import ./scripts/register-ts-extension-loader.mjs scripts/run-story-bible-l0b3-sqlite-export.mjs",
    "test:story-bible:l0b3:sqlite-revert": "node --experimental-strip-types --import ./scripts/register-ts-extension-loader.mjs scripts/run-story-bible-l0b3-sqlite-revert.mjs",
    "test:story-bible:l0b3:sqlite-backup": "node --experimental-strip-types --import ./scripts/register-ts-extension-loader.mjs scripts/run-story-bible-l0b3-sqlite-disaster-recovery.mjs backup",
    "test:story-bible:l0b3:sqlite-restore": "node --experimental-strip-types --import ./scripts/register-ts-extension-loader.mjs scripts/run-story-bible-l0b3-sqlite-disaster-recovery.mjs restore",
    "test:story-bible:l0b3:sqlite-wal-recovery": "node --experimental-strip-types --import ./scripts/register-ts-extension-loader.mjs scripts/run-story-bible-l0b3-sqlite-disaster-recovery.mjs wal",
    "test:story-bible:l0b3:sqlite-corruption": "node --experimental-strip-types --import ./scripts/register-ts-extension-loader.mjs scripts/run-story-bible-l0b3-sqlite-disaster-recovery.mjs corruption",
    "test:story-bible:l0b3b:all": "pnpm build && pnpm check:storage-boundaries && pnpm test:story-bible:l0b1:sqlite-foundation && pnpm test:story-bible:l0b2:sqlite-core && pnpm test:story-bible:l0b3:sqlite-export && pnpm test:story-bible:l0b3:sqlite-revert",
    "test:story-bible:l0b3c:all": "pnpm build && pnpm check:storage-boundaries && pnpm test:story-bible:l0b1:sqlite-foundation && pnpm test:story-bible:l0b2:sqlite-core && pnpm test:story-bible:l0b3:sqlite-export && pnpm test:story-bible:l0b3:sqlite-revert && node --experimental-strip-types --import ./scripts/register-ts-extension-loader.mjs scripts/run-story-bible-l0b3-sqlite-disaster-recovery.mjs all",
    "check:storage-boundaries": "node scripts/check-storage-boundaries.mjs"
  },
  "dependencies": {
    "@ai-sdk/google": "^4.0.12",
    "ai": "^7.0.22",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
